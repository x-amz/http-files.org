---
/**
 * Renders a feature comparison table for a given category.
 * Usage in Markdoc: {% support-table category="core" /%}
 * Data source: src/data/features.yaml
 */
import yaml from 'js-yaml';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
	category: string;
}

const { category } = Astro.props;

const featuresPath = path.resolve('src/data/features.yaml');
const featuresData = yaml.load(fs.readFileSync(featuresPath, 'utf8')) as any;
const clientsPath = path.resolve('src/data/clients.yaml');
const clientsData = yaml.load(fs.readFileSync(clientsPath, 'utf8')) as any;

const cat = featuresData.categories[category];
if (!cat) throw new Error(`Unknown feature category: ${category}`);

// The five primary clients for comparison
const primaryClients = ['vscode', 'jetbrains', 'httpyac', 'vs2022', 'kulala'];
const clientNames = primaryClients.map(id => clientsData.clients[id]?.shortName || id);

function supportIcon(value: any): string {
	if (value === true) return '✓';
	if (value === false) return '✗';
	if (value === 'partial') return '◐';
	return '?';
}

function supportClass(value: any): string {
	if (value === true) return 'yes';
	if (value === false) return 'no';
	if (value === 'partial') return 'partial';
	return 'unknown';
}
---

<div class="support-table-wrapper">
	<table class="support-table">
		<thead>
			<tr>
				<th class="feature-col">Feature</th>
				{clientNames.map(name => <th class="client-col">{name}</th>)}
			</tr>
		</thead>
		<tbody>
			{cat.features.map((feature: any) => (
				<tr class={feature.universal ? 'universal' : ''}>
					<td class="feature-name">
						<span>{feature.name}</span>
						{feature.notes && <span class="feature-note">{feature.notes}</span>}
					</td>
					{primaryClients.map(clientId => {
						const val = feature.support?.[clientId];
						return (
							<td class={`support-cell ${supportClass(val)}`} title={`${clientsData.clients[clientId]?.shortName}: ${val}`}>
								<span class="support-icon">{supportIcon(val)}</span>
							</td>
						);
					})}
				</tr>
			))}
		</tbody>
	</table>
</div>

<style>
	.support-table-wrapper {
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	.support-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}

	.support-table th,
	.support-table td {
		padding: 0.6rem 0.8rem;
		border: 1px solid var(--sl-color-gray-5);
		text-align: center;
	}

	.support-table th {
		background: var(--sl-color-gray-6);
		font-weight: 600;
		font-size: 0.8rem;
		white-space: nowrap;
	}

	.feature-col {
		text-align: left !important;
		min-width: 200px;
	}

	.client-col {
		min-width: 80px;
	}

	.feature-name {
		text-align: left !important;
	}

	.feature-name span:first-child {
		display: block;
		font-weight: 500;
	}

	.feature-note {
		display: block;
		font-size: 0.78rem;
		color: var(--sl-color-gray-3);
		margin-top: 0.2rem;
		line-height: 1.3;
	}

	tr.universal {
		background: var(--sl-color-gray-7, rgba(0, 128, 0, 0.03));
	}

	.support-cell {
		font-size: 1.1rem;
		font-weight: 600;
	}

	.support-cell.yes {
		color: var(--sl-color-green);
	}

	.support-cell.no {
		color: var(--sl-color-gray-4);
	}

	.support-cell.partial {
		color: var(--sl-color-orange);
	}

	.support-icon {
		display: inline-block;
	}

	.support-cell.yes .support-icon {
		color: var(--neon-green, #39ff14);
	}

	.support-cell.no .support-icon {
		color: var(--sl-color-gray-4);
	}

	.support-cell.partial .support-icon {
		color: var(--neon-yellow, #ffe600);
	}
</style>
